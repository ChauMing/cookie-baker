{
  "manifest_version": 3,
  "name": "cookie baker",
  "version": "1.1.0",
  "description": "transfer cookie from a domain to another",
  "icons": { "128": "128.png" },
  "action": {
    "default_icon": { "128": "128.png" },
    "default_title": "cookie baker",
    "default_popup": "src/popup.html"
  },
  "permissions": [
    "tabs",
    "cookies",
    "storage",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  }
}
