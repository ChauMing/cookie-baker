{
  "manifest_version": 3,
  "name": "cookie baker",
  "version": "1.2.0",
  "description": "transfer cookie from a domain to another",
  "icons": { "128": "128.png" },
  "action": {
    "default_icon": { "128": "128.png" },
    "default_title": "cookie baker",
    "default_popup": "src/popup.html"
  },
  "permissions": [
    "tabs",
    "cookies",
    "storage",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.ts"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
